{
  "realm": "myapp-frontend",
  "enabled": true,
  "displayName": "MyApp Frontend",
  "loginTheme": "keywind",

  "registrationAllowed": true,
  "resetPasswordAllowed": true,
  "verifyEmail": false,

  "otpPolicyType": "totp",
  "otpPolicyAlgorithm": "HmacSHA1",
  "otpPolicyDigits": 6,
  "otpPolicyPeriod": 30,
  "otpPolicyLookAheadWindow": 1,

  "clients": [
    {
      "clientId": "myapp-frontend",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": [
        "http://localhost:5173/*",
        "http://localhost:5173",
        "http://localhost:4173/*",
        "http://localhost:4173",
        "http://localhost:3000/*",
        "http://localhost:3000",
        "http://YOUR_EC2_PUBLIC_IP:3000/*",
        "http://YOUR_EC2_PUBLIC_IP:8081/*",
        "https://your-app-production-domain.com/*"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "http://localhost:4173",
        "http://localhost:3000",
        "http://YOUR_EC2_PUBLIC_IP:3000",
        "http://YOUR_EC2_PUBLIC_IP:8081",
        "https://your-app-production-domain.com"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    },
    {
      "clientId": "myapp-frontend-2",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": [
        "http://localhost:5174/*",
        "http://localhost:5174",
        "http://localhost:4174/*",
        "http://localhost:4174",
        "http://localhost:3001/*",
        "http://localhost:3001",
        "http://YOUR_EC2_PUBLIC_IP:3001/*"
      ],
      "webOrigins": [
        "http://localhost:5174",
        "http://localhost:4174",
        "http://localhost:3001",
        "http://YOUR_EC2_PUBLIC_IP:3001"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    }
  ],

  "identityProviders": [
    {
      "alias": "google",
      "providerId": "google",
      "enabled": true,
      "trustEmail": true,
      "storeToken": false,
      "addReadTokenRoleOnCreate": false,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "clientId": "${env.GOOGLE_CLIENT_ID}",
        "clientSecret": "${env.GOOGLE_CLIENT_SECRET}",
        "defaultScope": "openid profile email",
        "syncMode": "IMPORT"
      }
    }
  ]
}
